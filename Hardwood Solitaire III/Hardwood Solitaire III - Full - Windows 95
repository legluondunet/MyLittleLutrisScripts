files:
- os_img: https://lutris.nyc3.cdn.digitaloceanspaces.com/games/Windows_95/WIN95_OSR25_DBP_2Go.7z
- dbpu_file: https://github.com/legluondunet/mlls-tools/raw/refs/heads/master/DOSBox/dosbox-pure-unleashed.tar.xz
- game_file: https://archive.org/download/hardwood-solitaire-iii-full-version/HardwoodSolitaire%20III%20%28full%20version%29.rar
game:
  args: $GAMEDIR/D
  exe: $GAMEDIR/DOSBoxPure_x86_64
  working_dir: $GAMEDIR
installer:
- extract:
    dst: $GAMEDIR
    file: dbpu_file
- extract:
    dst: $GAMEDIR/system
    file: os_img
- extract:
    dst: $GAMEDIR/D
    file: game_file
    format: rar
- write_file:
    content: O*WIN95_OSR25_DBP_2Go
    file: $GAMEDIR/D/AUTOBOOT.DBP
